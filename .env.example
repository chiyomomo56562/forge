# ============================================================
# Forge — Environment Variables (Template)
# 실제 .env 파일은 이 파일을 복사하여 작성:  cp .env.example .env
# ============================================================

# --- LLM API Keys ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- LLM Model Selection ---
# 사용할 LLM 백엔드: openai | anthropic | local
LLM_BACKEND=openai
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# --- Embedding Model ---
# 로컬 임베딩: sentence-transformers 모델명
# API 임베딩: openai (text-embedding-3-small)
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Database Paths (프로젝트 루트 기준 상대 경로) ---
CHROMA_DB_PATH=data/memory/episodic/chroma
SKILLS_DB_PATH=data/memory/procedural/skills.sqlite3
IDENTITY_DB_PATH=identity/identity.sqlite3
GRAPH_PATH=data/memory/semantic/graph/knowledge_graph.graphml

# --- Constitution ---
CONSTITUTION_DIR=constitution

# --- Identity ---
IDENTITY_DIR=identity

# --- Runs ---
RUNS_DIR=runs

# --- Logging ---
LOG_LEVEL=INFO