# ============================================================
# Forge — Environment Variables (Template)
# 실제 .env 파일은 이 파일을 복사하여 작성:  cp .env.example .env
# ============================================================

# --- LLM API Keys ---
# OpenAI (Codex SDK) — backend=openai 시 사용
OPENAI_API_KEY=sk-...
# Ollama — backend=ollama 시 사용 (클라우드 원격 엔드포인트 설정)
OLLAMA_BASE_URL=http://localhost:11434

# --- LLM Model Selection ---
# 백엔드: ollama | openai
LLM_BACKEND=ollama
# Ollama 모델명 (GLM 5.2)
LLM_MODEL=glm-5.2
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=120000

# --- Embedding Model ---
# 로컬 임베딩: sentence-transformers 모델명
# API 임베딩: openai (text-embedding-3-small)
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Database Paths (프로젝트 루트 기준 상대 경로) ---
CHROMA_DB_PATH=data/memory/episodic/chroma
SKILLS_DB_PATH=data/memory/procedural/skills.sqlite3
IDENTITY_DB_PATH=identity/identity.sqlite3
GRAPH_PATH=data/memory/semantic/graph/knowledge_graph.graphml

# --- Constitution ---
CONSTITUTION_DIR=constitution

# --- Identity ---
IDENTITY_DIR=identity

# --- Working Memory (이너 루프 임시 결과 스테이징) ---
WORKING_DIR=data/memory/working
SESSIONS_DIR=data/memory/working/sessions

# --- Logging ---
LOG_LEVEL=INFO